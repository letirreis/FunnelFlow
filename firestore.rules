rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isAuthenticated() && (
        getUserRole() == 'admin' ||
        (request.auth.token.email == "letirreis@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    function isColaborador() {
      return isAuthenticated() && getUserRole() == 'colaborador';
    }
    function isInfra() {
      return isAuthenticated() && getUserRole() == 'infra';
    }
    function hasStaffAccess() {
      return isAdmin() || isColaborador() || isInfra();
    }

    // Funnels
    match /funnels/{funnelId} {
      allow read: if true; // Publicly readable for the renderer
      allow create: if hasStaffAccess();
      allow update: if (hasStaffAccess() && (resource.data.ownerId == request.auth.uid || isAdmin())) || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'leadsCount']));
      allow delete: if isAdmin() || (hasStaffAccess() && resource.data.ownerId == request.auth.uid); // Drastic action

      match /questions/{questionId} {
        allow read: if true;
        allow write: if hasStaffAccess();
        
        match /options/{optionId} {
          allow read: if true;
          allow write: if hasStaffAccess();
        }
      }

      match /diagnoses/{diagnosisId} {
        allow read: if true;
        allow write: if hasStaffAccess();
      }
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuthenticated() && (isAdmin() || isColaborador());
      allow create: if true; // Publicly creatable by respondents
      allow update: if isAdmin() || (resource.data.status == 'incomplete');
      allow delete: if isAdmin();
    }

    // Responses
    match /responses/{responseId} {
      allow read: if isAuthenticated() && (isAdmin() || isColaborador());
      allow create: if true; // Publicly creatable by respondents
      allow update, delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }
  }
}
